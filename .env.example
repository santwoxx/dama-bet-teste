# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Mercado Pago Integration Secrets
# NOTE: the backend reads MERCADOPAGO_ACCESS_TOKEN (no underscore between
# MERCADO and PAGO). Set that exact name in Render — otherwise deposits
# silently fall back to mock PIX codes and never receive real money.
MERCADOPAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=

# Vercel KV (Redis) — auto-injected when KV store is linked in Vercel dashboard
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# --- Backend (Render) — set these directly in the Render dashboard, not here ---

# DATABASE_URL: Postgres connection string. REQUIRED for production — without it
# the backend falls back to storing users/balances/deposits in a local JSON file
# on the server's disk, which is lost on every redeploy/restart.
# DATABASE_URL=

# JWT_SECRET: signs login session tokens. REQUIRED in production (the server
# refuses to start without it) — otherwise anyone with the source code could
# forge a valid session token for any account, including the admin account.
# JWT_SECRET=

# ADMIN_PASSWORD: password for the seeded admin account (id "user_admin"), used
# only the first time the server boots and no admin account exists yet. If
# unset, a random password is generated and printed once to the server logs.
# ADMIN_PASSWORD=

# ADMIN_USER_IDS: comma-separated list of user IDs allowed to approve/reject
# withdrawals via /api/admin/*. Defaults to "user_admin" if unset.
# ADMIN_USER_IDS=user_admin

